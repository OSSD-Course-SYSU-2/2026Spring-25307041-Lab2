/**
 * 屏幕工具类
 */
export class ScreenUtil {
  /**
   * 获取屏幕宽度
   */
  static getScreenWidth(): number {
    // 简化实现，实际应使用display API
    return 360
  }

  /**
   * 获取屏幕高度
   */
  static getScreenHeight(): number {
    // 简化实现，实际应使用display API
    return 640
  }

  /**
   * vp转px
   */
  static vp2px(vp: number): number {
    // 简化实现，实际应使用vp2px API
    return vp
  }

  /**
   * px转vp
   */
  static px2vp(px: number): number {
    // 简化实现，实际应使用px2vp API
    return px
  }
}
